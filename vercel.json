{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist/client" }
    },
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": "dist/server/**",
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/assets/(.*)", "dest": "/dist/client/assets/$1" },
    { "src": "/favicon.ico", "dest": "/dist/client/favicon.ico" },
    { "src": "(.*\\.(js|css|png|jpg|jpeg|svg|ico|webp|json|map))$", "dest": "/dist/client/$1" },
    { "src": "(.*)", "dest": "/api/index.js" }
  ]
}